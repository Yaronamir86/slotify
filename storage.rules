rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    match /business-assets/{businessId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /customer-uploads/{uid}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }
  }
}
