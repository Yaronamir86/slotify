rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function businessDoc(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId));
    }

    function isOwner(businessId) {
      return signedIn() && businessDoc(businessId).data.ownerUid == request.auth.uid;
    }

    function isStaff(businessId) {
      return signedIn()
        && ('staffUids' in businessDoc(businessId).data)
        && request.auth.uid in businessDoc(businessId).data.staffUids;
    }

    function isBusinessAdmin(businessId) {
      return isOwner(businessId) || isStaff(businessId);
    }

    function isOwnUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwnUserDoc(uid);
    }

    match /businesses/{businessId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isBusinessAdmin(businessId);

      match /services/{serviceId} {
        allow read: if true;
        allow create, update, delete: if isBusinessAdmin(businessId);
      }

      match /employees/{employeeId} {
        allow read: if true;
        allow create, update, delete: if isBusinessAdmin(businessId);
      }

      match /bookings/{bookingId} {
        allow read: if isBusinessAdmin(businessId)
          || (signedIn() && resource.data.customerUid == request.auth.uid);

        allow create: if signedIn()
          && request.resource.data.customerUid == request.auth.uid;

        allow update, delete: if isBusinessAdmin(businessId)
          || (signedIn() && resource.data.customerUid == request.auth.uid);
      }

      match /settings/{docId} {
        allow read: if true;
        allow create, update, delete: if isBusinessAdmin(businessId);
      }
    }
  }
}
